{
  "name": "mileboard-mini-floating",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.mile.board.mini",
    "productName": "Mile Board Mini Floating",
    "directories": { "output": "dist" },
    "win": { "target": "nsis", "icon": "icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "publish": null ,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  }
}
